# ==========================================
# 1. GÜVENLİK VE ORTAM DEĞİŞKENLERİ (SECRETS)
# ==========================================
# API anahtarları (Gemini vb.) ve lokal konfigürasyonlar asla repoya gitmemelidir.
.env
.env.*
secrets.toml
*.pem

# ==========================================
# 2. PYTHON EKOSİSTEMİ VE DERLEME (COMPILATION)
# ==========================================
# Derlenmiş bytecode'lar ve sanal ortamlar (virtual environments) yoksayılır.
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.uv/

# ==========================================
# 3. TYPESCRIPT / NODE.JS EKOSİSTEMİ
# ==========================================
# pnpm ve npm bağımlılıkları yoksayılır. (package.json ve lock dosyaları kalır)
node_modules/
dist/
build/
.npm/
.pnpm-store/
.tsbuildinfo

# ==========================================
# 4. VERİ BORU HATTI (ETL PIPELINE) MEDYALARI
# ==========================================
# Kurum fiyat listeleri gibi ham PDF'ler repoda değil, lokalde veya blob storage'da tutulur.
attached_assets/
*.pdf
*.csv
*.xlsx
*.xls

# ==========================================
# 5. VERİTABANI VE VEKTÖR UZAYI (STATEFUL DATA)
# ==========================================
# İşlenmiş JSON verileri, lokal veritabanları ve semantik arama endeksleri yoksayılır.
*.db
*.sqlite
*.sqlite3
*.parquet
chroma_db/
faiss_index/

# ==========================================
# 6. PLATFORM VE IDE KONFİGÜRASYONLARI
# ==========================================
# Replit, VS Code veya işletim sistemi spesifik metadata dosyaları temizlenir.
.replit
.upm
.vscode/
.idea/
.DS_Store
Thumbs.db